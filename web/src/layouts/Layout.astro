---
import '../styles/global.css';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const {
	title = 'Semillas de Ti | Coaching emocional por Zoraida Pozo Barrio',
	description = 'Semillas de Ti — coaching emocional e introspección en movimiento por Zoraida Pozo Barrio. Caminar, sentir, escribir y comprender para crear cambios reales desde dentro.',
	image = '/images/hero.jpg',
	noindex = false,
	structuredData,
} = Astro.props;

const siteUrl = Astro.site?.toString() || 'https://semillasdeti.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = typeof image === 'string' && image.startsWith('http') ? image : new URL(image, siteUrl).toString();
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Source+Sans+3:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Semillas de Ti" />
		<meta property="og:locale" content="es_ES" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		{import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
			<meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION} />
		)}
		{structuredData && (
			<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
		)}
	</head>
	<body class="bg-sand text-cacao antialiased">
		<slot />
		<WhatsAppButton />
	</body>
</html>
