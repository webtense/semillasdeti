---
import Layout from '../layouts/Layout.astro';
import { getSiteContent } from '../lib/content';
import CalendlyEmbed from '../components/CalendlyEmbed.astro';

export const prerender = false;

const site = await getSiteContent();
const whatsappNumber = site.contact.whatsappNumber.replace(/\D/g, '');
const defaultWhatsappMessage =
	import.meta.env.PUBLIC_WHATSAPP_MESSAGE ||
	'Hola Zoraida, me gustaría reservar una llamada para conocerte mejor.';
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(defaultWhatsappMessage)}`;

const brevoListId = import.meta.env.PUBLIC_BREVO_LIST_ID || '';
const newsletterDisabled = !brevoListId || !import.meta.env.BREVO_API_KEY;
const currentYear = new Date().getFullYear();
const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	'@id': 'https://semillasdeti.com/#organization',
	name: site.brand.name,
	url: 'https://semillasdeti.com/',
	description: site.hero.description,
	email: site.contact.email,
	telephone: site.contact.whatsappNumber,
	areaServed: ['Madrid', 'Barcelona', 'España'],
	serviceType: [...site.services.items.map((service) => service.title), 'Introspección en movimiento', 'Escucha emocional caminando'],
	knowsAbout: ['Coaching emocional', 'Introspección en movimiento', 'Bienestar emocional', 'Escritura terapéutica', 'Meditación activa'],
};

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	'@id': 'https://semillasdeti.com/#person',
	name: 'Zoraida Pozo Barrio',
	jobTitle: 'Coach emocional y profesional',
	worksFor: { '@id': 'https://semillasdeti.com/#organization' },
	url: 'https://semillasdeti.com/',
	email: site.contact.email,
	telephone: site.contact.whatsappNumber,
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': 'https://semillasdeti.com/#website',
	name: site.brand.name,
	url: 'https://semillasdeti.com/',
	inLanguage: 'es-ES',
};

const howToSchema = {
	'@context': 'https://schema.org',
	'@type': 'HowTo',
	name: 'Introspección en movimiento: cómo escucharte caminando',
	description: 'Proceso de 6 pasos para practicar la introspección a través del movimiento, las notas de voz y la escritura.',
	step: site.origin.process.steps.map((s, i) => ({
		'@type': 'HowToStep',
		position: i + 1,
		name: s.verb,
		text: s.detail,
	})),
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: '¿Qué es Semillas de Ti?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: `${site.origin.whatIs.description} ${site.origin.whatIs.detail}`,
			},
		},
		{
			'@type': 'Question',
			name: '¿Es Semillas de Ti una terapia o servicio psicológico?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: `No. ${site.origin.whatIsNot.items.join(' ')} ${site.origin.whatIsNot.closing}`,
			},
		},
		{
			'@type': 'Question',
			name: '¿Cómo funciona la introspección en movimiento?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: `El proceso tiene 6 pasos: ${site.origin.process.steps.map((s) => `${s.verb} (${s.detail})`).join('; ')}.`,
			},
		},
		{
			'@type': 'Question',
			name: '¿Cómo puedo reservar una sesión con Zoraida Pozo Barrio?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: `Puedes reservar una llamada exploratoria gratuita de 25 minutos contactando por WhatsApp al ${site.contact.whatsappNumber} o por email a ${site.contact.email}. Modalidad: ${site.contact.mode}.`,
			},
		},
	],
};
---

<Layout structuredData={[websiteSchema, organizationSchema, personSchema, howToSchema, faqSchema]}>
	<header class="sticky top-0 z-30 bg-sand/95 backdrop-blur-md border-b border-clay/60">
		<div class="section-shell flex items-center justify-between py-4">
			<div>
				<p class="tagline text-sienna tracking-[0.3em] text-xs">{site.brand.name}</p>
				<p class="text-sm text-cacao/70">{site.brand.subtitle}</p>
			</div>
			<nav class="hidden md:flex items-center gap-6 text-sm">
				{site.navLinks.map((link) => (
					<a class="text-cacao/80 hover:text-sienna transition-colors" href={link.href}>{link.label}</a>
				))}
			</nav>
			<a
				href="#contacto"
				class="hidden md:inline-flex items-center gap-2 rounded-full bg-sienna text-white px-5 py-2 text-sm shadow-soft"
			>
				{site.hero.primaryCta}
			</a>
		</div>
	</header>

	<main>
		<section class="section-shell grid gap-10 py-20 items-center lg:grid-cols-[1.1fr_0.9fr]">
			<div>
				<p class="tagline text-sienna/80">{site.hero.tagline}</p>
				<h1 class="text-4xl sm:text-5xl font-serif text-cacao leading-tight mt-4">{site.hero.title}</h1>
				<p class="text-lg text-cacao/80 mt-5 max-w-xl">{site.hero.description}</p>
				<div class="flex flex-col sm:flex-row gap-4 mt-8">
					<a
						href="#contacto"
						class="inline-flex items-center justify-center rounded-full bg-sienna text-white px-7 py-3 font-medium shadow-soft"
					>
						{site.hero.primaryCta}
					</a>
					<a
						href={whatsappLink}
						class="inline-flex items-center justify-center rounded-full border border-sienna/40 px-7 py-3 font-medium text-sienna"
						target="_blank"
						rel="noopener noreferrer"
					>
						{site.hero.secondaryCta}
					</a>
				</div>
				<div class="mt-10 grid gap-6 sm:grid-cols-3">
					{site.stats.map((item) => (
						<div class="soft-card rounded-2xl p-4 text-center">
							<p class="text-3xl font-serif text-sienna">{item.value}</p>
							<p class="text-sm text-cacao/70">{item.label}</p>
						</div>
					))}
</div>
			<CalendlyEmbed />
		</div>
	</section>

		<section id="origen" class="py-24 overflow-hidden">
			<div class="section-shell">

				<div class="mb-14">
					<p class="tagline text-sienna/80">{site.origin.tagline}</p>
					<h2 class="font-serif text-cacao mt-4 text-7xl sm:text-9xl leading-none tracking-tight opacity-90">{site.origin.dateLabel}</h2>
				</div>

				<div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-12 lg:gap-16 items-start">
					<div class="space-y-5 text-lg text-cacao/80 leading-[1.85]">
						{site.origin.manifesto.map((p, i) => (
							i === 1
								? <blockquote class="border-l-2 border-sienna/40 pl-6 text-2xl font-serif text-cacao/90 italic my-8 leading-snug">{p}</blockquote>
								: <p>{p}</p>
						))}
						<p class="text-xl font-serif text-sienna pt-2">{site.origin.insight}</p>
						<p class="text-cacao/60 text-base italic pt-2">{site.origin.quote}</p>
					</div>
					<div class="lg:sticky lg:top-28">
						<div class="rounded-[2.5rem] overflow-hidden shadow-soft">
							<img
								src={site.origin.image1}
								alt={site.origin.imageAlt}
								class="w-full object-cover"
								style="aspect-ratio:3/4;"
								loading="lazy"
							/>
						</div>
					</div>
				</div>

				<div class="mt-24 grid lg:grid-cols-[0.45fr_1fr] gap-12 items-center">
					<div class="rounded-[2rem] overflow-hidden shadow-soft">
						<img
							src={site.origin.image2}
							alt={site.origin.imageAlt}
							class="w-full object-cover"
							style="aspect-ratio:4/3;"
							loading="lazy"
						/>
					</div>
					<div>
						<p class="tagline text-sienna/80">{site.origin.whatIs.tagline}</p>
						<p class="text-2xl font-serif text-cacao mt-4 leading-snug">{site.origin.whatIs.description}</p>
						<p class="text-cacao/70 mt-4 text-lg leading-relaxed">{site.origin.whatIs.detail}</p>

						<div class="mt-10 border border-clay/50 rounded-2xl bg-white/60 p-6">
							<p class="tagline text-sienna/80 mb-5">{site.origin.whatIsNot.tagline}</p>
							<ul class="space-y-2 text-cacao/70">
								{site.origin.whatIsNot.items.map((item) => (
									<li class="flex gap-3 items-start">
										<span class="text-sienna/40 select-none leading-7">—</span>
										<span>{item}</span>
									</li>
								))}
							</ul>
							<p class="mt-5 text-cacao/60 text-sm italic">{site.origin.whatIsNot.closing}</p>
						</div>
					</div>
				</div>

				<div class="mt-24">
					<p class="tagline text-sienna/80 mb-10">{site.origin.process.tagline}</p>
					<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-10">
						{site.origin.process.steps.map((step, i) => (
							<div class="flex gap-5 items-start">
								<span class="text-6xl font-serif text-sienna/15 leading-none select-none flex-shrink-0">{i + 1}</span>
								<div class="pt-2">
									<p class="font-serif text-2xl text-cacao">{step.verb}</p>
									<p class="text-sm text-cacao/60 mt-1 leading-relaxed">{step.detail}</p>
								</div>
							</div>
						))}
					</div>
				</div>

			</div>
		</section>

		<section id="quien-soy" class="py-20 bg-white/70">
			<div class="section-shell grid gap-12 lg:grid-cols-2 items-center">
				<div class="order-2 lg:order-1">
					<p class="tagline text-sienna/80">{site.about.tagline}</p>
					<h2 class="text-3xl font-serif text-cacao mt-4">{site.about.title}</h2>
					<p class="text-lg text-cacao/80 mt-4">{site.about.description}</p>
					<ul class="mt-6 space-y-3 text-cacao/80">
						{site.about.bullets.map((bullet) => (
							<li>✔ {bullet}</li>
						))}
					</ul>
					<p class="mt-6 text-cacao/70">{site.about.closing}</p>
				</div>
				<div class="order-1 lg:order-2">
					<div class="soft-card rounded-[32px] p-10">
						<p class="text-sm uppercase tracking-[0.4em] text-sienna/80">{site.about.valuesTitle}</p>
						<ul class="mt-6 space-y-5">
							{site.about.values.map((value) => (
								<li>
									<p class="font-serif text-xl text-cacao">{value.title}</p>
									<p class="text-cacao/70">{value.description}</p>
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section id="metodo" class="py-20">
			<div class="section-shell">
				<p class="tagline text-sienna/80">{site.method.tagline}</p>
				<h2 class="text-3xl font-serif text-cacao mt-4 max-w-3xl">{site.method.title}</h2>
				{site.method.description && (
					<p class="text-cacao/65 mt-3 max-w-xl text-lg">{site.method.description}</p>
				)}
				<div class="mt-10 grid gap-6 md:grid-cols-3">
					{site.method.steps.map((step, index) => (
						<div class="soft-card rounded-3xl p-6 flex flex-col gap-4">
							<div class="w-12 h-12 rounded-full bg-clay flex items-center justify-center text-cacao font-semibold">
								{index + 1}
							</div>
							<h3 class="text-xl font-serif text-cacao">{step.title}</h3>
							<p class="text-cacao/70">{step.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section id="servicios" class="py-20 bg-white/80">
			<div class="section-shell">
				<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
					<div>
						<p class="tagline text-sienna/80">{site.services.tagline}</p>
						<h2 class="text-3xl font-serif text-cacao mt-4">{site.services.title}</h2>
					</div>
					<p class="text-cacao/70 max-w-lg">{site.services.description}</p>
				</div>
				<div class="mt-10 grid gap-8 lg:grid-cols-3">
					{site.services.items.map((service) => (
						<article class="soft-card rounded-[28px] p-8 flex flex-col gap-4">
							<h3 class="text-2xl font-serif text-cacao">{service.title}</h3>
							<p class="text-cacao/70">{service.description}</p>
							<ul class="mt-4 space-y-2 text-cacao/80">
								{service.benefits.map((benefit) => (
									<li>• {benefit}</li>
								))}
							</ul>
							<div class="mt-auto pt-6">
								<a href="#contacto" class="text-sienna font-semibold">Quiero este proceso →</a>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section id="testimonios" class="py-20">
			<div class="section-shell">
				<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
					<div>
						<p class="tagline text-sienna/80">{site.testimonials.tagline}</p>
						<h2 class="text-3xl font-serif text-cacao mt-4">{site.testimonials.title}</h2>
					</div>
					<p class="text-cacao/70 max-w-2xl">{site.testimonials.description}</p>
				</div>
				<div class="mt-10 grid gap-6 lg:grid-cols-3">
					{site.testimonials.items.map((testimonial) => (
						<figure class="soft-card rounded-[28px] p-7 flex flex-col gap-4">
							<blockquote class="text-cacao/80">“{testimonial.quote}”</blockquote>
							<figcaption>
								<p class="font-semibold text-cacao">{testimonial.name}</p>
								<p class="text-sm text-cacao/60">{testimonial.role}</p>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<section id="newsletter" class="py-20 bg-white/90">
			<div class="section-shell grid gap-10 lg:grid-cols-2 items-center">
				<div class="rounded-[32px] overflow-hidden shadow-soft">
					<img src={site.newsletter.image} alt={site.newsletter.imageAlt} class="w-full h-full object-cover" loading="lazy" />
				</div>
				<div>
					<p class="tagline text-sienna/80">{site.newsletter.tagline}</p>
					<h2 class="text-3xl font-serif text-cacao mt-4">{site.newsletter.title}</h2>
					<p class="text-cacao/70 mt-4">{site.newsletter.description}</p>
					<form class="mt-6 space-y-4" id="download-form">
						<div>
							<label class="text-sm text-cacao/70">Nombre</label>
							<input
								type="text"
								name="firstName"
								required
								placeholder="Tu nombre"
								class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3"
							/>
						</div>
						<div>
							<label class="text-sm text-cacao/70">Correo</label>
							<input
								type="email"
								name="email"
								required
								placeholder="tu@email.com"
								class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3"
							/>
						</div>
						<label class="flex items-start gap-3 text-sm text-cacao/70">
							<input type="checkbox" required class="mt-1" />Acepto recibir comunicaciones de Semillas de Ti.
						</label>
						<button type="submit" class="w-full rounded-full bg-sienna text-white py-3 font-medium">
							{site.newsletter.cta}
						</button>
						<p id="download-status" class="text-sm text-cacao/70"></p>
					</form>
				</div>
			</div>
		</section>

		<section id="contacto" class="py-20">
			<div class="section-shell grid gap-10 lg:grid-cols-[1fr_0.9fr] items-center">
				<div>
					<p class="tagline text-sienna/80">{site.contact.tagline}</p>
					<h2 class="text-3xl font-serif text-cacao mt-4">{site.contact.title}</h2>
					<p class="text-cacao/70 mt-4">{site.contact.description}</p>
					<ul class="mt-8 space-y-4 text-cacao/80">
						<li><span class="font-semibold">{site.contact.whatsappLabel}:</span> <a class="text-sienna" href={whatsappLink} target="_blank" rel="noopener noreferrer">{site.contact.whatsappNumber}</a></li>
						<li><span class="font-semibold">Email:</span> <a class="text-sienna" href={`mailto:${site.contact.email}`}>{site.contact.email}</a></li>
						<li><span class="font-semibold">Modalidad:</span> {site.contact.mode}</li>
					</ul>
				</div>
				<div class="soft-card rounded-[32px] p-8 space-y-4">
					<div>
						<label class="text-sm text-cacao/70">Nombre</label>
						<input type="text" placeholder="Tu nombre" class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3" />
					</div>
					<div>
						<label class="text-sm text-cacao/70">Email</label>
						<input type="email" placeholder="tu@email.com" class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3" />
					</div>
					<div>
						<label class="text-sm text-cacao/70">¿Qué te gustaría trabajar?</label>
						<textarea rows="4" placeholder="Cuéntame brevemente" class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3"></textarea>
					</div>
					<p class="text-xs text-cacao/60">{site.contact.formDisclaimer}</p>
					<a
						href={`mailto:${site.contact.email}?subject=${encodeURIComponent(site.contact.mailtoSubject)}`}
						class="block text-center rounded-full bg-sienna text-white py-3 font-medium"
					>
						{site.contact.formCta}
					</a>
				</div>
			</div>
		</section>
	</main>

	<footer class="bg-cacao text-sand py-12">
		<div class="section-shell flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
			<div>
				<p class="font-serif text-2xl">{site.brand.name}</p>
				<p class="text-sm text-sand/80">{site.footer.description}</p>
			</div>
			<div class="text-sm space-y-1">
				<p>Email: <a class="text-white" href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
				<p>{site.contact.whatsappLabel}: <a class="text-white" href={whatsappLink} target="_blank" rel="noopener noreferrer">{site.contact.whatsappNumber}</a></p>
			</div>
		</div>
		<div class="section-shell text-xs text-sand/60 mt-6">
			<p>© {currentYear} {site.brand.name}. Todos los derechos reservados.</p>
		</div>
	</footer>

	<a
		href={whatsappLink}
		class="fixed bottom-6 right-6 z-40 inline-flex items-center gap-2 rounded-full bg-sage text-white px-4 py-3 shadow-soft"
		target="_blank"
		rel="noopener noreferrer"
	>
		<span class="text-sm font-semibold">WhatsApp</span>
	</a>

	<script is:inline>
		const form = document.querySelector('#download-form');
		const status = document.querySelector('#download-status');
		const button = form?.querySelector('button[type="submit"]');
		if (form && status && button) {
			form.addEventListener(
				'submit',
				async (event) => {
					event.preventDefault();
					status.textContent = 'Enviando...';
					status.className = 'text-sm text-cacao/60';
					button.disabled = true;
					const formData = new FormData(form);
					const payload = {
						firstName: String(formData.get('firstName') || ''),
						email: String(formData.get('email') || ''),
					};
					try {
						const response = await fetch('/api/download-guide', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify(payload),
						});
						const result = await response.json().catch(() => ({ message: 'Error inesperado' }));
						status.textContent = result.message || (response.ok ? '¡Gracias! Tu guía está en camino.' : 'No se pudo procesar tu solicitud.');
						status.className = response.ok ? 'text-sm text-sage font-medium' : 'text-sm text-sienna font-medium';
						if (response.ok) {
							form.reset();
						}
					} catch (error) {
						status.textContent = 'No pudimos conectar con el servicio. Intenta de nuevo en unos minutos.';
						status.className = 'text-sm text-sienna font-medium';
					} finally {
						button.disabled = false;
					}
				},
				{ passive: false }
			);
		}
	</script>
</Layout>
