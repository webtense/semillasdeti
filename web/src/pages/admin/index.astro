---
import Layout from '../../layouts/Layout.astro';
import { CSRF_COOKIE_NAME, SESSION_COOKIE_NAME, getSessionUsername } from '../../lib/auth';
import { getSiteContent } from '../../lib/content';
import { getLeads } from '../../lib/leads';
import { getListContactCount } from '../../lib/brevo';
import { listUsers } from '../../lib/admin-users';

export const prerender = false;

const content = await getSiteContent();
const contentJson = JSON.stringify(content, null, 2);
const csrfToken = Astro.cookies.get(CSRF_COOKIE_NAME)?.value ?? '';
const saved = Astro.url.searchParams.get('saved') === '1';
const uploaded = Astro.url.searchParams.get('uploaded');
const error = Astro.url.searchParams.get('error') ?? '';
const rebuild = Astro.url.searchParams.get('rebuild') ?? '';
const tab = Astro.url.searchParams.get('tab') || 'content';
const emailSent = Astro.url.searchParams.get('emailsent') === '1';
const emailError = Astro.url.searchParams.get('emailerror') ?? '';

const leads = tab === 'leads' || tab === 'mailing' ? await getLeads() : [];
const brevoListId = Number(import.meta.env.PUBLIC_BREVO_LIST_ID || '1');
const brevoCount = tab === 'mailing' ? await getListContactCount(brevoListId) : -1;

const adminUsers = tab === 'usuarios' ? await listUsers() : [];
const currentUsername = getSessionUsername(Astro.cookies.get(SESSION_COOKIE_NAME)?.value);
const userSaved = Astro.url.searchParams.get('usersaved') === '1';
const userDeleted = Astro.url.searchParams.get('userdeleted') === '1';
const pwChanged = Astro.url.searchParams.get('pwchanged') === '1';
const userError = Astro.url.searchParams.get('usererror') ?? '';

const userErrorMap: Record<string, string> = {
	short: 'El nombre de usuario debe tener al menos 3 caracteres.',
	weakpass: 'La contraseña debe tener al menos 8 caracteres.',
	mismatch: 'Las contraseñas no coinciden.',
	exists: 'Ese nombre de usuario ya existe.',
	cantdelete: 'No se puede eliminar el único usuario activo.',
	notfound: 'Usuario no encontrado.',
};

const errorMap: Record<string, string> = {
	auth: 'Tu sesión expiró. Vuelve a iniciar sesión.',
	csrf: 'No se pudo validar la sesión del formulario. Recarga la página e intenta otra vez.',
	json: 'El JSON no es válido. Revisa el formato antes de guardar.',
	toolarge: 'El bloque de contenido excede el tamaño permitido.',
	upload: 'No se pudo subir la imagen. Verifica formato y tamaño.',
	missing: 'Faltan datos obligatorios en la petición.',

};

const rebuildMap: Record<string, string> = {
	ok: 'Comando de rebuild ejecutado correctamente.',
	missing: 'No hay comando de rebuild configurado. Define ADMIN_REDEPLOY_COMMAND en .env.',
	invalid: 'El comando de rebuild tiene caracteres no permitidos por seguridad.',
	error: 'El rebuild falló. Revisa logs del servidor.',
};
---

<Layout title="Panel admin | Semillas de Ti" description="Panel de administración Semillas de Ti" noindex={true}>
	<main class="section-shell py-10 md:py-14 space-y-8">
		<header class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
			<div>
				<p class="tagline text-sienna/80">Panel de administración</p>
				<h1 class="text-3xl font-serif text-cacao mt-3">Editar contenido público</h1>
			</div>
			<nav class="flex gap-2 flex-wrap">
				<a href="/admin?tab=content" class={`px-4 py-2 rounded-full text-sm font-medium ${tab === 'content' ? 'bg-sienna text-white' : 'border border-sienna/40 text-sienna'}`}>Contenido</a>
				<a href="/admin?tab=leads" class={`px-4 py-2 rounded-full text-sm font-medium ${tab === 'leads' ? 'bg-sienna text-white' : 'border border-sienna/40 text-sienna'}`}>Leads</a>
				<a href="/admin?tab=mailing" class={`px-4 py-2 rounded-full text-sm font-medium ${tab === 'mailing' ? 'bg-sienna text-white' : 'border border-sienna/40 text-sienna'}`}>Mailing</a>
				<a href="/admin?tab=usuarios" class={`px-4 py-2 rounded-full text-sm font-medium ${tab === 'usuarios' ? 'bg-sienna text-white' : 'border border-sienna/40 text-sienna'}`}>Usuarios</a>
			</nav>
			<form method="post" action="/api/admin/logout">
				<input type="hidden" name="csrfToken" value={csrfToken} />
				<button class="rounded-full border border-sienna/40 px-5 py-2 text-sienna font-semibold">Cerrar sesión</button>
			</form>
		</header>

		{userSaved && <p class="rounded-2xl bg-sage/10 text-sage px-4 py-3 text-sm">Usuario creado correctamente.</p>}
		{userDeleted && <p class="rounded-2xl bg-sage/10 text-sage px-4 py-3 text-sm">Usuario eliminado.</p>}
		{pwChanged && <p class="rounded-2xl bg-sage/10 text-sage px-4 py-3 text-sm">Contraseña actualizada correctamente.</p>}
		{userError && userErrorMap[userError] && <p class="rounded-2xl bg-sienna/10 text-sienna px-4 py-3 text-sm">{userErrorMap[userError]}</p>}
		{saved && <p class="rounded-2xl bg-sage/10 text-sage px-4 py-3 text-sm">Contenido guardado correctamente.</p>}
		{emailSent && <p class="rounded-2xl bg-sage/10 text-sage px-4 py-3 text-sm">Email de prueba enviado correctamente. Revisa tu bandeja.</p>}
		{emailError && <p class="rounded-2xl bg-sienna/10 text-sienna px-4 py-3 text-sm">Error al enviar el email: {emailError}</p>}
		{uploaded && (
			<p class="rounded-2xl bg-sage/10 text-sage px-4 py-3 text-sm">
				Imagen subida con éxito: <code>{uploaded}</code>
			</p>
		)}
		{error && errorMap[error] && <p class="rounded-2xl bg-sienna/10 text-sienna px-4 py-3 text-sm">{errorMap[error]}</p>}
		{rebuild && rebuildMap[rebuild] && (
			<p class={`rounded-2xl px-4 py-3 text-sm ${rebuild === 'ok' ? 'bg-sage/10 text-sage' : 'bg-sienna/10 text-sienna'}`}>
				{rebuildMap[rebuild]}
			</p>
		)}

		{tab === 'usuarios' ? (
			<div class="space-y-6">
				<!-- Lista de usuarios -->
				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao mb-2">Usuarios con acceso al panel</h2>
					<p class="text-cacao/70 mb-6">Cada usuario puede iniciar sesión en <code>/admin</code> con su usuario y contraseña.</p>
					<div class="overflow-x-auto">
						<table class="w-full text-sm">
							<thead>
								<tr class="border-b border-clay/60">
									<th class="text-left py-3 px-4 font-semibold text-cacao">Usuario</th>
									<th class="text-left py-3 px-4 font-semibold text-cacao">Creado</th>
									<th class="py-3 px-4"></th>
								</tr>
							</thead>
							<tbody>
								{adminUsers.map((u) => (
									<tr class="border-b border-clay/30">
										<td class="py-3 px-4 font-medium">
											{u.username}
											{u.username === currentUsername && <span class="ml-2 text-xs text-sienna/70">(tú)</span>}
										</td>
										<td class="py-3 px-4 text-cacao/60">{new Date(u.createdAt).toLocaleDateString('es-ES')}</td>
										<td class="py-3 px-4 text-right">
											{adminUsers.length > 1 && (
												<form method="post" action="/api/admin/users" class="inline">
													<input type="hidden" name="csrfToken" value={csrfToken} />
													<input type="hidden" name="action" value="delete" />
													<input type="hidden" name="id" value={u.id} />
													<button
														type="submit"
														class="text-xs text-sienna/70 hover:text-sienna border border-sienna/30 hover:border-sienna/60 rounded-full px-3 py-1 transition-colors"
														onclick="return confirm('¿Eliminar este usuario?')"
													>Eliminar</button>
												</form>
											)}
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</section>

				<!-- Añadir usuario -->
				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao mb-2">Añadir usuario</h2>
					<p class="text-cacao/70 mb-5">Crea acceso para otra persona (mínimo 8 caracteres en la contraseña).</p>
					<form method="post" action="/api/admin/users" class="grid sm:grid-cols-3 gap-3">
						<input type="hidden" name="csrfToken" value={csrfToken} />
						<input type="hidden" name="action" value="add" />
						<div>
							<label class="text-xs text-cacao/60 mb-1 block">Usuario</label>
							<input type="text" name="username" required minlength="3"
								placeholder="zoraida"
								class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3 text-sm" />
						</div>
						<div>
							<label class="text-xs text-cacao/60 mb-1 block">Contraseña</label>
							<input type="password" name="password" required minlength="8"
								placeholder="••••••••"
								class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3 text-sm" />
						</div>
						<div>
							<label class="text-xs text-cacao/60 mb-1 block">Confirmar contraseña</label>
							<input type="password" name="confirm" required minlength="8"
								placeholder="••••••••"
								class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3 text-sm" />
						</div>
						<div class="sm:col-span-3 flex justify-end">
							<button type="submit" class="rounded-full bg-sienna text-white px-6 py-3 font-medium text-sm">Crear usuario</button>
						</div>
					</form>
				</section>

				<!-- Cambiar mi contraseña -->
				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao mb-2">Cambiar mi contraseña</h2>
					<p class="text-cacao/70 mb-5">Sesión activa como <strong>{currentUsername}</strong>.</p>
					<form method="post" action="/api/admin/users" class="grid sm:grid-cols-2 gap-3">
						<input type="hidden" name="csrfToken" value={csrfToken} />
						<input type="hidden" name="action" value="change-password" />
						<div>
							<label class="text-xs text-cacao/60 mb-1 block">Nueva contraseña</label>
							<input type="password" name="newPassword" required minlength="8"
								placeholder="••••••••"
								class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3 text-sm" />
						</div>
						<div>
							<label class="text-xs text-cacao/60 mb-1 block">Confirmar nueva contraseña</label>
							<input type="password" name="confirmPassword" required minlength="8"
								placeholder="••••••••"
								class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3 text-sm" />
						</div>
						<div class="sm:col-span-2 flex justify-end">
							<button type="submit" class="rounded-full border border-sienna/40 text-sienna px-6 py-3 font-medium text-sm">Actualizar contraseña</button>
						</div>
					</form>
				</section>
			</div>
		) : tab === 'mailing' ? (
			<div class="space-y-6">
				<!-- Stats -->
				<div class="grid sm:grid-cols-3 gap-4">
					<div class="soft-card rounded-2xl p-6 text-center">
						<p class="text-3xl font-serif text-sienna">{leads.length}</p>
						<p class="text-sm text-cacao/70 mt-1">Leads locales</p>
					</div>
					<div class="soft-card rounded-2xl p-6 text-center">
						<p class="text-3xl font-serif text-sienna">{brevoCount >= 0 ? brevoCount : '—'}</p>
						<p class="text-sm text-cacao/70 mt-1">Contactos en Brevo</p>
					</div>
					<div class="soft-card rounded-2xl p-6 text-center">
						<p class="text-3xl font-serif text-sienna">200</p>
						<p class="text-sm text-cacao/70 mt-1">Objetivo 60 días</p>
					</div>
				</div>

				<!-- Estado de la integración -->
				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao mb-4">Estado del mailing</h2>
					<ul class="space-y-3 text-sm">
						<li class="flex items-center gap-3">
							<span class="w-2 h-2 rounded-full bg-sage flex-shrink-0"></span>
							<span class="text-cacao/80">Brevo configurado — Lista ID: <code class="text-sienna">{brevoListId}</code></span>
						</li>
						<li class="flex items-center gap-3">
							<span class="w-2 h-2 rounded-full bg-sage flex-shrink-0"></span>
							<span class="text-cacao/80">Lead magnet activo: "5 Anclas para Volver a Ti" — enviado automáticamente al registrarse</span>
						</li>
						<li class="flex items-center gap-3">
							<span class="w-2 h-2 rounded-full bg-sage flex-shrink-0"></span>
							<span class="text-cacao/80">Contacto se añade a la lista Brevo en cada registro</span>
						</li>
						<li class="flex items-center gap-3">
							<span class="w-2 h-2 rounded-full bg-clay flex-shrink-0"></span>
							<span class="text-cacao/80">Automatización Brevo: configurar en el panel de Brevo una secuencia de bienvenida adicional (día 3, día 7)</span>
						</li>
					</ul>
				</section>

				<!-- Test email -->
				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao mb-2">Enviar email de prueba</h2>
					<p class="text-cacao/70 mb-5">Envía la guía "5 Anclas" a cualquier dirección para verificar que el email llega correctamente.</p>
					<form id="test-email-form" class="flex flex-col sm:flex-row gap-3">
						<input type="hidden" name="csrfToken" value={csrfToken} />
						<input
							type="email"
							name="email"
							required
							placeholder="email@ejemplo.com"
							class="flex-1 rounded-2xl border border-clay/60 bg-white px-4 py-3 text-sm"
						/>
						<input
							type="text"
							name="firstName"
							placeholder="Nombre (opcional)"
							class="w-full sm:w-40 rounded-2xl border border-clay/60 bg-white px-4 py-3 text-sm"
						/>
						<button type="submit" class="rounded-full bg-sienna text-white px-6 py-3 font-medium text-sm">Enviar prueba</button>
					</form>
					<p id="test-status" class="text-sm mt-3 text-cacao/60"></p>
				</section>

				<!-- Guía del flujo -->
				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao mb-4">Flujo de captación</h2>
					<ol class="space-y-3 text-sm text-cacao/80">
						<li class="flex gap-3"><span class="font-semibold text-sienna flex-shrink-0">1.</span> Visitante rellena el formulario en la sección Newsletter de la web</li>
						<li class="flex gap-3"><span class="font-semibold text-sienna flex-shrink-0">2.</span> Se guarda el lead localmente (leads.json) como backup</li>
						<li class="flex gap-3"><span class="font-semibold text-sienna flex-shrink-0">3.</span> Se añade el contacto a la lista {brevoListId} de Brevo con el nombre</li>
						<li class="flex gap-3"><span class="font-semibold text-sienna flex-shrink-0">4.</span> Se envía el email con la guía "5 Anclas" vía Brevo transactional</li>
						<li class="flex gap-3"><span class="font-semibold text-sienna flex-shrink-0">5.</span> <span>Desde el panel de <strong>Brevo → Automatizaciones</strong>, puedes activar una secuencia: día 3 (reflexión) y día 7 (CTA sesión)</span></li>
					</ol>
				</section>
			</div>
		) : tab === 'leads' ? (
			<section class="soft-card rounded-[28px] p-6 md:p-8">
				<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
					<div>
						<h2 class="text-2xl font-serif text-cacao">Leads registrados</h2>
						<p class="text-cacao/70 mt-1">Personas que han descargado la guía "5 Anclas"</p>
					</div>
					<form action="/api/admin/leads" method="post">
						<input type="hidden" name="csrfToken" value={csrfToken} />
						<input type="hidden" name="action" value="export-csv" />
						<button type="submit" class="rounded-full border border-sienna/40 px-6 py-3 text-sienna font-semibold">Exportar CSV</button>
					</form>
				</div>

				{leads.length === 0 ? (
					<p class="text-cacao/60">Aún no hay leads registrados.</p>
				) : (
					<div class="overflow-x-auto">
						<table class="w-full text-sm">
							<thead>
								<tr class="border-b border-clay/60">
									<th class="text-left py-3 px-4 font-semibold text-cacao">Email</th>
									<th class="text-left py-3 px-4 font-semibold text-cacao">Nombre</th>
									<th class="text-left py-3 px-4 font-semibold text-cacao">Fecha de registro</th>
								</tr>
							</thead>
							<tbody>
								{leads.map((lead) => (
									<tr class="border-b border-clay/30">
										<td class="py-3 px-4">{lead.email}</td>
										<td class="py-3 px-4">{lead.firstName}</td>
										<td class="py-3 px-4">{new Date(lead.registeredAt).toLocaleString('es-ES')}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				)}

				<p class="text-xs text-cacao/60 mt-4">Total: {leads.length} leads</p>
			</section>
		) : (
			<>
				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao">Subir imagen</h2>
					<p class="text-cacao/70 mt-2">
						Sube JPG, PNG o WEBP (hasta 5MB). Luego usa la ruta en el JSON, por ejemplo <code>/images/uploads/archivo.jpg</code>.
					</p>
					<form action="/api/admin/upload" method="post" enctype="multipart/form-data" class="mt-5 flex flex-col gap-4 md:flex-row md:items-end">
						<input type="hidden" name="csrfToken" value={csrfToken} />
						<div class="w-full md:max-w-lg">
							<label class="text-sm text-cacao/70" for="image">Archivo</label>
							<input id="image" name="image" type="file" accept="image/png,image/jpeg,image/webp" required class="w-full rounded-2xl border border-clay/60 bg-white px-4 py-3" />
						</div>
						<button type="submit" class="rounded-full bg-sienna text-white px-6 py-3 font-medium">Subir</button>
					</form>
				</section>

				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao">Contenido del sitio (JSON)</h2>
					<p class="text-cacao/70 mt-2">
						Puedes editar textos, enlaces e imágenes desde aquí. Conserva la estructura para evitar errores.
					</p>
					<form action="/api/admin/content" method="post" class="mt-6 space-y-4">
						<input type="hidden" name="csrfToken" value={csrfToken} />
						<label class="sr-only" for="content-json">JSON de contenido</label>
						<textarea
							id="content-json"
							name="content"
							required
							class="w-full min-h-[560px] rounded-2xl border border-clay/60 bg-white px-4 py-4 font-mono text-sm leading-6"
						>{contentJson}</textarea>
						<div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
							<p class="text-sm text-cacao/60">Tip: guarda primero, revisa la portada y luego ajusta detalles finos.</p>
							<div class="flex gap-3">
								<button type="submit" class="rounded-full bg-sienna text-white px-6 py-3 font-medium">Guardar cambios</button>
							</div>
						</div>
					</form>
				</section>

				<section class="soft-card rounded-[28px] p-6 md:p-8">
					<h2 class="text-2xl font-serif text-cacao">Rebuild / Redeploy</h2>
					<p class="text-cacao/70 mt-2">
						Si tu despliegue requiere build manual, configura <code>ADMIN_REDEPLOY_COMMAND</code> y ejecútalo desde aquí.
					</p>
					<form action="/api/admin/rebuild" method="post" class="mt-5">
						<input type="hidden" name="csrfToken" value={csrfToken} />
						<button class="rounded-full border border-sienna/40 px-6 py-3 text-sienna font-semibold" type="submit">Ejecutar rebuild</button>
					</form>
				</section>
			</>
		)}
	</main>

<script is:inline>
	const testForm = document.querySelector('#test-email-form');
	const testStatus = document.querySelector('#test-status');
	if (testForm && testStatus) {
		testForm.addEventListener('submit', async (e) => {
			e.preventDefault();
			const form = e.target;
			const email = form.querySelector('[name="email"]').value;
			const firstName = form.querySelector('[name="firstName"]').value;
			testStatus.textContent = 'Enviando...';
			testStatus.className = 'text-sm mt-3 text-cacao/60';
			try {
				const res = await fetch('/api/download-guide', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, firstName }),
				});
				const data = await res.json().catch(() => ({}));
				testStatus.textContent = data.message || (res.ok ? 'Email enviado.' : 'Error al enviar.');
				testStatus.className = res.ok ? 'text-sm mt-3 text-sage font-medium' : 'text-sm mt-3 text-sienna font-medium';
			} catch {
				testStatus.textContent = 'Error de conexión.';
				testStatus.className = 'text-sm mt-3 text-sienna font-medium';
			}
		});
	}
</script>
</Layout>
