[Unit]
Description=Semillas de Ti Astro service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/semillasdeti
Environment=PORT=4173
Environment=NODE_ENV=production
Environment=HOST=0.0.0.0
EnvironmentFile=/etc/semillasdeti.env
ExecStart=/usr/bin/env node server/entry.mjs
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
